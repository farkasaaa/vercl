{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "https://fortissimo.andrisfarkas77.workers.dev/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Host", "value": "fortissimo.fandras.eu" },
        { "key": "X-Forwarded-Host", "value": "app.fortissimosportalapitvany.hu" },
        { "key": "X-Forwarded-Proto", "value": "https" },
        { "key": "X-Real-IP", "value": "remote_addr" },
        { "key": "Access-Control-Allow-Origin", "value": "https://app.fortissimosportalapitvany.hu" },
        { "key": "Access-Control-Allow-Credentials", "value": "true" }
      ]
    }
  ]
}
